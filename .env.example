API_ID=
API_HASH=
BOT_TOKEN=
OWNER_ID=
LOG_GROUP=

DOWNLOAD_PATH=downloads
TEMP_PATH=temp
MAX_FILE_SIZE=4294967296
MAX_CONCURRENT_DOWNLOADS=3

# yt-dlp auto-update — checks PyPI every YTDLP_CHECK_INTERVAL seconds,
# upgrades in-place, and restarts the process to apply it.
AUTO_UPDATE_YTDLP=true
YTDLP_CHECK_INTERVAL=86400

# Optional
COOKIES_FILE=
PROXY_URL=
